{
  "id": "app-worker",
  "kind": "app",
  "type": "worker",
  "version": "1.0.0",
  "displayName": "Worker Application",
  "description": "Background worker with service-oriented project structure",
  "runtime": "worker",
  "defaultPresets": ["redis", "queue", "testing"],
  "contributes": {
    "files": [
      {
        "source": "src/services/WorkerBootstrapService.ts.tpl",
        "destination": "src/services/WorkerBootstrapService.ts"
      },
      {
        "source": "src/types/jobs.ts.tpl",
        "destination": "src/types/jobs.ts"
      }
    ]
  }
}
