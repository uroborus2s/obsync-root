{
  "name": "@stratix/core",
  "version": "1.1.0",
  "description": "一个轻量级的Node.js应用框架，基于Fastify构建",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./async": {
      "import": "./dist/utils/async/index.js",
      "types": "./dist/types/utils/async/index.d.ts"
    },
    "./auth": {
      "import": "./dist/utils/auth/index.js",
      "types": "./dist/types/utils/auth/index.d.ts"
    },
    "./context": {
      "import": "./dist/utils/context/index.js",
      "types": "./dist/types/utils/context/index.d.ts"
    },
    "./contracts": {
      "import": "./dist/contracts/index.js",
      "types": "./dist/types/contracts/index.d.ts"
    },
    "./data": {
      "import": "./dist/utils/data/index.js",
      "types": "./dist/types/utils/data/index.d.ts"
    },
    "./diagnostics": {
      "import": "./dist/diagnostics/index.js",
      "types": "./dist/types/diagnostics/index.d.ts"
    },
    "./environment": {
      "import": "./dist/utils/environment/index.js",
      "types": "./dist/types/utils/environment/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "types": "./dist/types/errors/index.d.ts"
    },
    "./experimental": {
      "import": "./dist/experimental/index.js",
      "types": "./dist/types/experimental/index.d.ts"
    },
    "./functional": {
      "import": "./dist/utils/functional/index.js",
      "types": "./dist/types/utils/functional/index.d.ts"
    },
    "./internal": {
      "import": "./dist/internal/index.js",
      "types": "./dist/types/internal/index.d.ts"
    },
    "./logger": {
      "import": "./dist/logger/index.js",
      "types": "./dist/types/logger/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/public/plugin.js",
      "types": "./dist/types/public/plugin.d.ts"
    },
    "./service": {
      "import": "./dist/service/index.js",
      "types": "./dist/types/service/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/types/utils/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --ext .ts src",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "framework",
    "fastify",
    "node",
    "plugin",
    "server",
    "web"
  ],
  "author": "Stratix Team",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "awilix": "^13.0.5",
    "awilix-manager": "^7.0.0",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.2.0",
    "pino": "10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
