{
  "name": "@stratix/core",
  "version": "1.1.0",
  "description": "一个轻量级的Node.js应用框架，基于Fastify构建",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./async": {
      "import": "./dist/utils/async/index.js",
      "types": "./dist/types/utils/async/index.d.ts"
    },
    "./auth": {
      "import": "./dist/utils/auth/index.js",
      "types": "./dist/types/utils/auth/index.d.ts"
    },
    "./context": {
      "import": "./dist/utils/context/index.js",
      "types": "./dist/types/utils/context/index.d.ts"
    },
    "./data": {
      "import": "./dist/utils/data/index.js",
      "types": "./dist/types/utils/data/index.d.ts"
    },
    "./environment": {
      "import": "./dist/utils/environment/index.js",
      "types": "./dist/types/utils/environment/index.d.ts"
    },
    "./functional": {
      "import": "./dist/utils/functional/index.js",
      "types": "./dist/types/utils/functional/index.d.ts"
    },
    "./logger": {
      "import": "./dist/logger/index.js",
      "types": "./dist/types/logger/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/types/utils/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --ext .ts src",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "framework",
    "fastify",
    "node",
    "plugin",
    "server",
    "web"
  ],
  "author": "Stratix Team",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "awilix": "^12.0.5",
    "awilix-manager": "^6.1.0",
    "dotenv": "^16.4.7",
    "dotenv-expand": "^12.0.2",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "js-yaml": "^4.1.0",
    "pino": "9.7.0",
    "pino-roll": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "pino-pretty": "^13.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
