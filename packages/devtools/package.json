{
  "name": "@stratix/devtools",
  "version": "1.0.0-beta.1",
  "description": "Developer tools and dashboard for Stratix framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json && pnpm --dir client build",
    "clean": "rimraf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "stratix",
    "devtools",
    "dashboard",
    "fastify"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@stratix/core": "workspace:*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "awilix": "^13.0.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
