{
  "name": "@stratix/database",
  "version": "1.1.0",
  "description": "Stratix Database Plugin with two-layer architecture, Kysely integration and advanced features",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc",
    "build:watch": "tsc --watch",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:unit": "vitest run tests/*.test.ts --exclude tests/integration.test.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "stratix",
    "database",
    "kysely",
    "orm",
    "postgresql",
    "mysql",
    "sqlite",
    "typescript",
    "plugin"
  ],
  "author": "Stratix Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratix/stratix-database.git"
  },
  "bugs": {
    "url": "https://github.com/stratix/stratix-database/issues"
  },
  "homepage": "https://github.com/stratix/stratix-database#readme",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "kysely": "^0.29.2",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@stratix/core": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "tarn": "^3.0.2",
    "tedious": "^19.2.1"
  },
  "devDependencies": {
    "@stratix/core": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "tarn": "^3.0.2",
    "tedious": "^19.2.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
