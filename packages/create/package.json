{
  "name": "@stratix/create",
  "version": "1.1.0",
  "description": "Lightweight Stratix project and plugin creation entrypoint",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "bin": {
    "create-stratix": "dist/bin/create-stratix.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "node --experimental-transform-types --loader ./tests/ts-loader.mjs --test tests/create.test.ts",
    "test:watch": "node --experimental-transform-types --loader ./tests/ts-loader.mjs --test --watch tests/create.test.ts",
    "lint": "eslint --ext .ts src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {},
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "stratix",
    "create",
    "scaffold",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
