{
  "name": "@obsync/root",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:supported",
    "build:all": "turbo run build --filter='./packages/*'",
    "build:supported": "turbo run build --filter='./packages/*'",
    "build:pkg": "turbo run build --filter=\"$npm_config_pkg\"",
    "dev": "turbo run dev --filter=\"$npm_config_pkg\"",
    "lint": "pnpm run lint:supported",
    "lint:supported": "turbo run lint --filter='./packages/*' --filter='./packages/devtools/client'",
    "lint:pkg": "turbo run lint --filter=\"$npm_config_pkg\"",
    "clean": "turbo run clean",
    "test": "pnpm run test:supported",
    "test:supported": "turbo run test --filter='./packages/*'",
    "test:coverage:core": "pnpm --filter @stratix/core run test:coverage",
    "smoke:core-api": "node packages/core/scripts/smoke-packed-api.mjs",
    "typecheck:supported": "pnpm --filter @stratix/core exec tsc -p tsconfig.json --noEmit && pnpm --filter @stratix/create exec tsc -p tsconfig.json --noEmit && pnpm --filter @stratix/database exec tsc -p tsconfig.json --noEmit && pnpm --filter @stratix/devtools exec tsc -p tsconfig.json --noEmit && pnpm --filter @stratix/forge exec tsc -p tsconfig.json --noEmit && pnpm --filter @stratix/ossp exec tsc -p tsconfig.json --noEmit && pnpm --filter @stratix/queue exec tsc -p tsconfig.json --noEmit && pnpm --filter @stratix/redis exec tsc -p tsconfig.json --noEmit && pnpm --filter @stratix/testing exec tsc -p tsconfig.json --noEmit && pnpm --filter @stratix/was-v7 exec tsc -p tsconfig.json --noEmit",
    "docs:validate": "node scripts/docs-validate.mjs",
    "security:audit": "pnpm audit --prod --audit-level high",
    "release:gate:dry-run": "node packages/forge/dist/bin/stratix.js release gate --scope workspace --dry-run",
    "release:gate": "node packages/forge/dist/bin/stratix.js release gate --scope workspace --include-offline-install --include-registry",
    "quality:release": "pnpm run build:supported && pnpm run typecheck:supported && pnpm run lint && pnpm run test:supported && pnpm run test:coverage:core && pnpm run smoke:core-api && pnpm run docs:validate && pnpm run security:audit && pnpm run release:gate:dry-run",
    "release": "pnpm run quality:release && pnpm run release:gate && pnpm changeset publish",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/eslintrc": "^3.3.5",
    "@microsoft/api-documenter": "^7.30.7",
    "@microsoft/api-extractor": "^7.58.9",
    "@tsconfig/recommended": "^1.0.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "node-ssh": "^13.2.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.0.0",
    "typescript": "^6.0.0",
    "pnpm": ">=11.0.0"
  }
}
