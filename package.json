{
  "name": "@obsync/root",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:all",
    "build:all": "turbo run build --filter=./packages/*",
    "build:pkg": "turbo run build --filter=\"$npm_config_pkg\"",
    "dev": "turbo run dev --filter=\"$npm_config_pkg\"",
    "lint": "turbo run lint",
    "lint:pkg": "turbo run lint --filter=\"$npm_config_pkg\"",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "release": "pnpm run build:all && pnpm changeset publish",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/eslintrc": "^3.3.5",
    "@microsoft/api-documenter": "^7.29.7",
    "@microsoft/api-extractor": "^7.57.7",
    "@tsconfig/recommended": "^1.0.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-ssh": "^13.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=24.0.0",
    "typescript": "^6.0.0",
    "pnpm": ">=10.33.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
